rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isHardcodedAdmin() {
      return isAuthenticated()
        && request.auth.uid == 'Loeyivasx8YGMPfN8NUAFcZVSAJ3';
    }

    function isAdmin() {
      return isHardcodedAdmin()
        || (isAuthenticated()
          && exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    function isArtisan() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/artisans/$(request.auth.uid));
    }

    function isBookingOwner() {
      return isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    function isNewBookingOwner() {
      return isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
    }

    // ─── Default deny ────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── Users — own profile only ────────────────────────────────
    match /users/{userId} {
      allow read, create, update: if isOwner(userId);
      allow delete: if false;
    }

    // ─── Bookings — customers own their bookings ─────────────────
    match /bookings/{bookingDocId} {
      allow create: if isNewBookingOwner()
        && request.resource.data.keys().hasAll([
          'bookingId', 'userId', 'status', 'serviceType',
          'serviceHours', 'address', 'schedule', 'pricing',
          'createdAt', 'updatedAt'
        ])
        && request.resource.data.status == 'confirmed';

      allow read: if isBookingOwner() || isAdmin()
        || (isArtisan() && resource.data.status in ['assigned', 'completed']);

      allow update: if isBookingOwner()
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'updatedAt'])
        || isAdmin();

      allow delete: if isAdmin();
    }

    // ─── Artisans — public read, self-write ──────────────────────
    match /artisans/{artisanId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(artisanId);
      allow update: if isOwner(artisanId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Admins — admin-only ─────────────────────────────────────
    match /admins/{adminId} {
      allow read: if isAdmin() || isOwner(adminId);
      allow write: if false; // managed via Firebase Console / Admin SDK only
    }

    // ─── Contracts (enterprise quotes) ─────────────────────────────
    match /contracts/{contractId} {
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }
  }
}
